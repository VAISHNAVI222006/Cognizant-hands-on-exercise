package com.cognizant.ormlearn;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;

import com.cognizant.ormlearn.model.Employee;
import com.cognizant.ormlearn.model.Product;
import com.cognizant.ormlearn.service.EmployeeService;
import com.cognizant.ormlearn.service.ProductService;

@SpringBootApplication
public class OrmLearnApplication {

    @Autowired
    private static EmployeeService employeeService;

    @Autowired
    private static ProductService productService;

    public static void main(String[] args) {

        var context = SpringApplication.run(
                OrmLearnApplication.class, args);

        employeeService = context.getBean(EmployeeService.class);
        productService = context.getBean(ProductService.class);

        // Hands-on 2
        System.out.println("Permanent Employees:");
        List<Employee> employees =
                employeeService.getAllPermanentEmployees();
        System.out.println(employees);

        // Hands-on 4
        System.out.println("Average Salary:");
        System.out.println(employeeService.getAverageSalary(1));

        // Hands-on 5
        System.out.println("Native Query:");
        System.out.println(employeeService.getAllEmployeesNative());

        // Hands-on 6
        System.out.println("Criteria Query:");
        List<Product> products =
                productService.searchProducts("8GB", "Windows");
        System.out.println(products);
    }
}
