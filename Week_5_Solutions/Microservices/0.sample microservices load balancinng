    public ReactiveHealthIndicator downstreamServiceHealth() {
        return () -> {
            // Check if all downstream services are healthy
            return checkDownstreamServices()
                .map(healthy -> {
                    if (healthy) {
                        return Health.up()
                            .withDetail("status", "All services healthy")
                            .build();
                    } else {
                        return Health.down()
                            .withDetail("status", "Some services are unhealthy")
                            .build();
                    }
                })
                .onErrorReturn(Health.down()
                    .withDetail("error", "Health check failed")
                    .build());
        };
    }
    
    private Mono<Boolean> checkDownstreamServices() {
        // In real implementation, you would check each service
        // This is a simplified version
        return Mono.just(true)
            .delayElement(Duration.ofSeconds(1));
    }
}

