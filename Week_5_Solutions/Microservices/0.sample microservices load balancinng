package com.example.gateway.validator;

import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.context.event.ApplicationReadyEvent;
import org.springframework.cloud.gateway.route.RouteDefinition;
import org.springframework.cloud.gateway.route.RouteDefinitionLocator;
import org.springframework.context.event.EventListener;
import org.springframework.stereotype.Component;

import java.util.List;

/**
 * Route Configuration Validator
 * Validates routes on application startup
 */
@Slf4j
@Component
public class RouteConfigurationValidator {
    
    @Autowired
    private RouteDefinitionLocator routeDefinitionLocator;
    
    @EventListener(ApplicationReadyEvent.class)
    public void validateRoutes() {
        log.info("Validating route configurations...");
        
        routeDefinitionLocator.getRouteDefinitions()
            .collectList()
            .subscribe(routes -> {
                log.info("Found {} route definitions", routes.size());
                validateRoutes(routes);
            });
    }
    
    private void validateRoutes(List<RouteDefinition> routes) {
        for (RouteDefinition route : routes) {
            boolean valid = validateRoute(route);
            if (valid) {
                log.info("✅ Route validation passed: {}", route.getId());
            } else {
                log.warn("⚠️ Route validation failed: {}", route.getId());
            }
        }
    }
    
    private boolean validateRoute(RouteDefinition route) {
        // Check if route has valid predicates
        if (route.getPredicates() == null || route.getPredicates().isEmpty()) {
            log.error("Route {} has no predicates", route.getId());
            return false;
        }
        
        // Check if route has valid URI
        if (route.getUri() == null) {
            log.error("Route {} has no URI", route.getId());
            return false;
        }
        
        return true;
    }
}

