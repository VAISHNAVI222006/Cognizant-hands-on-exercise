package com.example.gateway.config;

import org.springframework.cloud.gateway.route.RouteLocator;
import org.springframework.cloud.gateway.route.builder.RouteLocatorBuilder;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.http.HttpStatus;

/**
 * Advanced Route Configuration with Programmatic Routes
 */
@Configuration
public class GatewayRoutesConfig {
    
    /**
     * Configure routes programmatically with advanced filters
     */
    @Bean
    public RouteLocator advancedRouteLocator(RouteLocatorBuilder builder) {
        return builder.routes()
            // Exercise 1: Basic Routing with Custom Filters
            .route("basic_route", r -> r
                .path("/basic/**")
                .filters(f -> f
                    .addRequestHeader("X-Basic-Header", "BasicRoute")
                    .addResponseHeader("X-Basic-Response", "Processed")
                    .stripPrefix(1)
                )
                .uri("http://httpbin.org")
            )
            
            // Exercise 2: Load Balanced Route with Circuit Breaker
            .route("loadbalanced_route", r -> r
                .path("/loadbalanced/**")
                .filters(f -> f
                    .stripPrefix(1)
                    .circuitBreaker(config -> config
                        .setName("loadBalancedCircuitBreaker")
                        .setFallbackUri("forward:/fallback/loadbalanced")
                    )
                    .retry(retryConfig -> retryConfig
                        .setRetries(3)
                        .setStatuses(HttpStatus.INTERNAL_SERVER_ERROR)
                        .setMethods(HttpMethod.GET)
                    )
                )
                .uri("lb://example-service")
            )
            
            // Route with Custom Predicate
            .route("custom_predicate_route", r -> r
                .path("/custom/**")
                .and()
                .header("X-Custom-Header", "true")
                .filters(f -> f
                    .addRequestHeader("X-Custom-Predicate", "Matched")
                    .stripPrefix(1)
                )
                .uri("http://httpbin.org")
            )
            
            // Route with Multiple Resilience Patterns
            .route("resilient_route", r -> r
                .path("/resilient/**")
                .filters(f -> f
                    .stripPrefix(1)
                    .circuitBreaker(config -> config
                        .setName("resilientCircuitBreaker")
                        .setFallbackUri("forward:/fallback/resilient")
                    )
                    .retry(retryConfig -> retryConfig
                        .setRetries(5)
                        .setStatuses(HttpStatus.INTERNAL_SERVER_ERROR, HttpStatus.SERVICE_UNAVAILABLE)
                        .setMethods(HttpMethod.GET)
                        .setBackoff(100, 1000, 2, true)
                    )
                    .requestRateLimiter(config -> config
                        .setKeyResolver(new UserKeyResolver())
                        .setRateLimiter(redisRateLimiter())
                    )
                )
                .uri("lb://resilient-service")
            )
            
            // Route with Timeout Configuration
            .route("timeout_route", r -> r
                .path("/timeout/**")
                .filters(f -> f
                    .stripPrefix(1)
                    .setResponseTimeout(Duration.ofSeconds(3))
                    .circuitBreaker(config -> config
                        .setName("timeoutCircuitBreaker")
                        .setFallbackUri("forward:/fallback/timeout")
                    )
                )
                .uri("lb://timeout-service")
            )
            .build();
    }
    
    /**
     * Redis Rate Limiter Bean
     */
    @Bean
    public RedisRateLimiter redisRateLimiter() {
        return new RedisRateLimiter(10, 20, 1);
    }
}

