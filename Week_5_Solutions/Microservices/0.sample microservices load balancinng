 * 
 * Exercise 1 Extension: Custom Filter
 * - Adds custom processing logic
 * - Configurable via YAML
 */
@Slf4j
@Component
public class CustomFilterFactory extends AbstractGatewayFilterFactory<CustomFilterFactory.Config> {
    
    public CustomFilterFactory() {
        super(Config.class);
    }
    
    @Override
    public List<String> shortcutFieldOrder() {
        return List.of("enabled", "headerName", "headerValue");
    }
    
    @Override
    public GatewayFilter apply(Config config) {
        return (exchange, chain) -> {
            var request = exchange.getRequest();
            
            if (config.isEnabled()) {
                // Add custom header
                ServerHttpRequest modifiedRequest = request.mutate()
                    .header(config.getHeaderName(), config.getHeaderValue())
                    .header("X-Custom-Filter", "Applied")
                    .build();
                
                log.debug("Custom filter applied: {}={}", 
                    config.getHeaderName(), config.getHeaderValue());
                
                exchange = exchange.mutate()
                    .request(modifiedRequest)
                    .build();
            }
            
            // Add custom processing
            long startTime = System.currentTimeMillis();
            
            return chain.filter(exchange)
                .doFinally(signal -> {
                    long duration = System.currentTimeMillis() - startTime;
                    log.debug("Custom filter processing time: {} ms", duration);
                });
        };
    }
    
    @Data
    public static class Config {
        private boolean enabled = true;
        private String headerName = "X-Custom-Header";
        private String headerValue = "CustomValue";
