package com.example.gateway.config;

import org.springframework.cloud.gateway.filter.ratelimit.KeyResolver;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import reactor.core.publisher.Mono;

/**
 * User Key Resolver
 * Resolves keys for rate limiting based on user identity
 */
@Configuration
public class UserKeyResolver {
    
    /**
     * Resolve key based on user ID from JWT or IP address
     */
    @Bean
    public KeyResolver userKeyResolver() {
        return exchange -> {
            var request = exchange.getRequest();
            
            // Try to get user ID from headers (set by AuthenticationFilter)
            String userId = request.getHeaders().getFirst("X-User-Id");
            if (userId != null) {
                return Mono.just(userId);
            }
            
            // Fallback to client IP
            String clientIp = request.getRemoteAddress().getAddress().getHostAddress();
            return Mono.just(clientIp);
        };
    }
    
    /**
     * Resolve key based on API path
     */
    @Bean
    public KeyResolver apiKeyResolver() {
        return exchange -> {
            String path = exchange.getRequest().getPath().value();
            String method = exchange.getRequest().getMethod().name();
            return Mono.just(method + ":" + path);
        };
    }
    
    /**
     * Resolve key based on combination of user and path
     */
    @Bean
    public KeyResolver userAndApiKeyResolver() {
        return exchange -> {
            var request = exchange.getRequest();
            String userId = request.getHeaders().getFirst("X-User-Id");
            String path = request.getPath().value();
            
            if (userId == null) {
                userId = request.getRemoteAddress().getAddress().getHostAddress();
            }
            
            return Mono.just(userId + ":" + path);
        };
    }
}

