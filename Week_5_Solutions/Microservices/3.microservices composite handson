package com.cognizant.gateway.filter;

import org.springframework.cloud.gateway.filter.GatewayFilterChain;
import org.springframework.cloud.gateway.filter.GlobalFilter;
import org.springframework.core.Ordered;
import org.springframework.stereotype.Component;
import org.springframework.web.server.ServerWebExchange;
import reactor.core.publisher.Mono;

import java.time.LocalDateTime;
import java.util.concurrent.atomic.AtomicInteger;

/**
 * Global Logging Filter
 * Logs all incoming requests to the API Gateway
 * 
 * This is a Global Filter that runs for every request
 * Demonstrates:
 * - Request logging with timestamp
 * - URI, Method, Headers logging
 * - Response status and duration logging
 * - Error logging
 */
@Component
public class LogFilter implements GlobalFilter, Ordered {

    private final AtomicInteger requestCounter = new AtomicInteger(0);

    @Override
    public Mono<Void> filter(ServerWebExchange exchange, GatewayFilterChain chain) {
        long startTime = System.currentTimeMillis();
        int requestId = requestCounter.incrementAndGet();
        
        var request = exchange.getRequest();
        String uri = request.getURI().toString();
        String method = request.getMethod().name();
        String path = request.getPath().value();
        String queryParams = request.getQueryParams().toString();
        String headers = request.getHeaders().toString();

        // Log request details
        System.out.println("========================================");
        System.out.println("API GATEWAY REQUEST #" + requestId);
        System.out.println("========================================");
        System.out.println("Timestamp: " + LocalDateTime.now());
        System.out.println("Method: " + method);
        System.out.println("URI: " + uri);
        System.out.println("Path: " + path);
        System.out.println("Query Params: " + queryParams);
        System.out.println("Headers: " + headers);
        System.out.println("========================================");

        // Proceed with the filter chain
        return chain.filter(exchange)
            .doOnSuccess(aVoid -> {
                // Log response details on success
                long duration = System.currentTimeMillis() - startTime;
                var response = exchange.getResponse();
                int status = response.getStatusCode() != null ? 
                    response.getStatusCode().value() : 0;
                    
                System.out.println("========================================");
                System.out.println("API GATEWAY RESPONSE #" + requestId);
                System.out.println("========================================");
                System.out.println("Path: " + path);
                System.out.println("Status: " + status);
                System.out.println("Duration: " + duration + " ms");
                System.out.println("========================================");
            })
            .doOnError(error -> {
                // Log error details
                long duration = System.currentTimeMillis() - startTime;
                System.err.println("========================================");
                System.err.println("API GATEWAY ERROR #" + requestId);
                System.err.println("========================================");
                System.err.println("Path: " + path);
                System.err.println("Error: " + error.getMessage());
                System.err.println("Duration: " + duration + " ms");
                System.err.println("========================================");
                error.printStackTrace();
            });
    }

    @Override
    public int getOrder() {
        return -1; // Run before other filters
    }
}

