import java.util.Map;

@Service
public class LoanService {

    // Simulated database
    private Map<String, Loan> loanDatabase = new HashMap<>();

    public LoanService() {
        // Initialize with dummy data
        loanDatabase.put("H00987987972342", 
            new Loan("H00987987972342", "Home", 400000.00, 3258.00, 18, "John Doe", "Active"));
        loanDatabase.put("C00987987973456", 
            new Loan("C00987987973456", "Car", 300000.00, 2150.00, 12, "Jane Smith", "Active"));
        loanDatabase.put("P00987987978901", 
            new Loan("P00987987978901", "Personal", 100000.00, 950.00, 8, "Bob Johnson", "Active"));
    }

    public Loan getLoanByNumber(String number) {
        System.out.println("Fetching loan from database: " + number);
        
        // Simulate database access delay
        try {
            Thread.sleep(50);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }

        Loan loan = loanDatabase.get(number);
        if (loan == null) {
            // Return default loan if not found
            return new Loan(number, "Personal", 50000.00, 1000.00, 6, "Unknown", "Active");
        }
        return loan;
    }

    public Loan createLoan(Loan loan) {
        System.out.println("Creating loan: " + loan.getNumber());
        loanDatabase.put(loan.getNumber(), loan);
        return loan;
    }

    public Loan updateLoan(String number, Loan loan) {
        System.out.println("Updating loan: " + number);
        loanDatabase.put(number, loan);
        return loan;
    }
}

