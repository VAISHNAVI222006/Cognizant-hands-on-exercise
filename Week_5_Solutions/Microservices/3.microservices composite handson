package com.cognizant.account.controller;

import com.cognizant.account.model.Account;
import com.cognizant.account.service.AccountService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/accounts")
public class AccountController {

    @Autowired
    private AccountService accountService;

    /**
     * Get account details by account number
     * URL: GET /accounts/{number}
     * Response: Account details in JSON format
     */
    @GetMapping("/{number}")
    public Account getAccountByNumber(@PathVariable String number) {
        System.out.println("=== ACCOUNT SERVICE CALLED ===");
        System.out.println("Account Number: " + number);
        return accountService.getAccountByNumber(number);
    }

    /**
     * Create a new account
     * URL: POST /accounts
     */
    @PostMapping
    public Account createAccount(@RequestBody Account account) {
        System.out.println("=== CREATING NEW ACCOUNT ===");
        return accountService.createAccount(account);
    }

    /**
     * Update account details
     * URL: PUT /accounts/{number}
     */
    @PutMapping("/{number}")
    public Account updateAccount(@PathVariable String number, @RequestBody Account account) {
        System.out.println("=== UPDATING ACCOUNT ===");
        System.out.println("Account Number: " + number);
        return accountService.updateAccount(number, account);
    }

    /**
     * Delete account
     * URL: DELETE /accounts/{number}
     */
    @DeleteMapping("/{number}")
    public String deleteAccount(@PathVariable String number) {
        System.out.println("=== DELETING ACCOUNT ===");
        System.out.println("Account Number: " + number);
        return "Account " + number + " deleted successfully";
    }
}

