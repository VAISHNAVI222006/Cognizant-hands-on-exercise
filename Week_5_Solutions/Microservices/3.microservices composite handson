package com.cognizant.account.service;

import com.cognizant.account.model.Account;
import org.springframework.stereotype.Service;

import java.util.HashMap;
import java.util.Map;

@Service
public class AccountService {

    // Simulated database
    private Map<String, Account> accountDatabase = new HashMap<>();

    public AccountService() {
        // Initialize with dummy data
        accountDatabase.put("00987987973432", 
            new Account("00987987973432", "Savings", 234343.00, "John Doe", "BR001", "Active"));
        accountDatabase.put("00987987973433", 
            new Account("00987987973433", "Current", 150000.00, "Jane Smith", "BR002", "Active"));
        accountDatabase.put("00987987973434", 
            new Account("00987987973434", "Savings", 50000.00, "Bob Johnson", "BR001", "Active"));
    }

    public Account getAccountByNumber(String number) {
        System.out.println("Fetching account from database: " + number);
        
        // Simulate database access delay
        try {
            Thread.sleep(50);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }

        Account account = accountDatabase.get(number);
        if (account == null) {
            // Return default account if not found
            return new Account(number, "Savings", 10000.00, "Unknown", "BR000", "Active");
        }
        return account;
    }

    public Account createAccount(Account account) {
        System.out.println("Creating account: " + account.getNumber());
        accountDatabase.put(account.getNumber(), account);
        return account;
    }

    public Account updateAccount(String number, Account account) {
        System.out.println("Updating account: " + number);
        accountDatabase.put(number, account);
        return account;
    }
}

