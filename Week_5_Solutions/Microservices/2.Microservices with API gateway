package com.cognizant.gateway.config;

import org.springframework.cloud.gateway.route.RouteLocator;
import org.springframework.cloud.gateway.route.builder.RouteLocatorBuilder;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

/**
 * Custom Route Configuration
 * Demonstrates programmatic route configuration with filters
 */
@Configuration
public class GatewayRouteConfig {
    
    @Bean
    public RouteLocator customRouteLocator(RouteLocatorBuilder builder) {
        return builder.routes()
            // Route for Account Service
            .route("account_route", r -> r
                .path("/account-service/**")
                .filters(f -> f
                    .addRequestHeader("X-Gateway-Route", "account-route")
                    .addResponseHeader("X-Gateway-Response", "processed")
                    .stripPrefix(1)
                )
                .uri("lb://account-service")
            )
            // Route for Loan Service
            .route("loan_route", r -> r
                .path("/loan-service/**")
                .filters(f -> f
                    .addRequestHeader("X-Gateway-Route", "loan-route")
                    .addResponseHeader("X-Gateway-Response", "processed")
                    .stripPrefix(1)
                )
                .uri("lb://loan-service")
            )
            .build();
    }
}

