package com.cognizant.greet.controller;

import lombok.extern.slf4j.Slf4j;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestHeader;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import java.util.HashMap;
import java.util.Map;

@Slf4j
@RestController
@RequestMapping("/greet")
public class GreetController {
    
    @GetMapping
    public Map<String, String> greet(@RequestHeader(value = "X-Gateway-Route", required = false) String routeHeader) {
        log.info("Greet service called, route header: {}", routeHeader);
        
        Map<String, String> response = new HashMap<>();
        response.put("message", "Hello World!");
        response.put("service", "greet-service");
        response.put("timestamp", String.valueOf(System.currentTimeMillis()));
        
        if (routeHeader != null) {
            response.put("gateway-route", routeHeader);
        }
        
        return response;
    }
    
    @GetMapping("/hello")
    public String hello() {
        return "Hello from Greet Service!";
    }
}

