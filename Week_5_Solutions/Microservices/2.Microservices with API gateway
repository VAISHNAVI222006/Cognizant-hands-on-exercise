// ============================================================================
// 2.6 ACCOUNT MICROSERVICE - SERVICE
// ============================================================================
package com.cognizant.account.service;

import com.cognizant.account.model.Account;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

import java.util.HashMap;
import java.util.Map;

@Slf4j
@Service
public class AccountService {
    
    // Simulated database
    private final Map<String, Account> accountDatabase = new HashMap<>();
    
    public AccountService() {
        // Initialize with some dummy data
        accountDatabase.put("ACC12345", new Account("ACC12345", "Savings", 50000.00, "John Doe", "BR001", "Active"));
        accountDatabase.put("ACC67890", new Account("ACC67890", "Current", 150000.00, "Jane Smith", "BR002", "Active"));
        accountDatabase.put("ACC11111", new Account("ACC11111", "Savings", 25000.00, "Bob Johnson", "BR001", "Active"));
    }
    
    public Account getAccountByNumber(String number) {
        log.info("Retrieving account from database: {}", number);
        
        // Simulate database access delay
        try {
            Thread.sleep(100);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }
        
        Account account = accountDatabase.get(number);
        if (account == null) {
            log.warn("Account not found: {}", number);
            // Return dummy account if not found
            return new Account(number, "Savings", 10000.00, "Unknown Customer", "BR000", "Active");
        }
        
        return account;
    }
    
    public Account createAccount(Account account) {
        log.info("Creating account in database: {}", account.getNumber());
        accountDatabase.put(account.getNumber(), account);
        return account;
    }
}

