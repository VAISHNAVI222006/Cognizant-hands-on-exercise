        LOGGER.info("START - EmployeeService.getAllEmployees()");
        List<Employee> employees = employeeDao.getAllEmployees();
        LOGGER.info("END - EmployeeService.getAllEmployees()");
        return employees;
    }
    
    @Transactional
    public Employee getEmployeeById(int id) throws EmployeeNotFoundException {
        LOGGER.info("START - EmployeeService.getEmployeeById()");
        Employee employee = employeeDao.getEmployeeById(id);
        LOGGER.info("END - EmployeeService.getEmployeeById()");
        return employee;
    }
    
    @Transactional
    public void addEmployee(Employee employee) {
        LOGGER.info("START - EmployeeService.addEmployee()");
        employeeDao.addEmployee(employee);
        LOGGER.info("END - EmployeeService.addEmployee()");
    }
    
    @Transactional
    public void updateEmployee(Employee employee) throws EmployeeNotFoundException {
        LOGGER.info("START - EmployeeService.updateEmployee()");
        employeeDao.updateEmployee(employee);
        LOGGER.info("END - EmployeeService.updateEmployee()");
    }
    
    @Transactional
    public void deleteEmployee(int id) throws EmployeeNotFoundException {
        LOGGER.info("START - EmployeeService.deleteEmployee()");
        employeeDao.deleteEmployee(id);
        LOGGER.info("END - EmployeeService.deleteEmployee()");
    }
}

