/**
 * Employee Not Found Exception
 * Maps to HTTP 404 Not Found
 */
@ResponseStatus(value = HttpStatus.NOT_FOUND, reason = "Employee not found")
class EmployeeNotFoundException extends Exception {
    public EmployeeNotFoundException(String message) {
        super(message);
    }
}

/**
 * Global Exception Handler
 * @ControllerAdvice - Handles exceptions across all controllers
 * Extends ResponseEntityExceptionHandler for built-in exception handling
 * 
 * Handles:
 * 1. Validation errors (MethodArgumentNotValidException)
 * 2. JSON parsing errors (HttpMessageNotReadableException)
 * 3. Custom exceptions
 */
@ControllerAdvice
class GlobalExceptionHandler extends ResponseEntityExceptionHandler {
    
    private static final Logger LOGGER = LoggerFactory.getLogger(GlobalExceptionHandler.class);
    
    /**
     * Handle validation errors
     * Triggered when @Valid validation fails
     */
    @Override
    protected ResponseEntity<Object> handleMethodArgumentNotValid(
            MethodArgumentNotValidException ex,
            HttpHeaders headers, 
            HttpStatus status, 
            WebRequest request) {
        
        LOGGER.info("START - GlobalExceptionHandler.handleMethodArgumentNotValid()");
        
        // Create error response body
        Map<String, Object> body = new LinkedHashMap<>();
        body.put("timestamp", new Date());
        body.put("status", status.value());
        body.put("error", "Validation Failed");
        
        // Get all validation errors
        List<String> errors = ex.getBindingResult()
                .getFieldErrors()
                .stream()
                .map(x -> x.getDefaultMessage())
                .collect(Collectors.toList());
        
        body.put("errors", errors);
        
        LOGGER.debug("Validation errors: {}", errors);
        LOGGER.info("END - GlobalExceptionHandler.handleMethodArgumentNotValid()");
        
        return new ResponseEntity<>(body, headers, status);
    }
    
    /**
     * Handle JSON parsing errors
     * Triggered when invalid data type is provided (e.g., string for number)
     */
    @Override
    protected ResponseEntity<Object> handleHttpMessageNotReadable(
            HttpMessageNotReadableException ex,
            HttpHeaders headers,
            HttpStatus status,
            WebRequest request) {
        
        LOGGER.info("START - GlobalExceptionHandler.handleHttpMessageNotReadable()");
        
        Map<String, Object> body = new LinkedHashMap<>();
        body.put("timestamp", new Date());
        body.put("status", status.value());
        body.put("error", "Bad Request");
        
        List<String> errors = new ArrayList<>();
        
        // Handle InvalidFormatException (wrong data type)
        if (ex.getCause() instanceof InvalidFormatException) {
            InvalidFormatException ife = (InvalidFormatException) ex.getCause();
            for (InvalidFormatException.Reference reference : ife.getPath()) {
                String fieldName = reference.getFieldName();
                String errorMsg = "Incorrect format for field '" + fieldName + 
                                 "'. Expected numeric value.";
                errors.add(errorMsg);
                LOGGER.debug("Field error: {}", errorMsg);
            }
        } else {
            errors.add("Malformed JSON request");
        }
        
        body.put("errors", errors);
        
        LOGGER.info("END - GlobalExceptionHandler.handleHttpMessageNotReadable()");
        return new ResponseEntity<>(body, headers, status);
    }
}

