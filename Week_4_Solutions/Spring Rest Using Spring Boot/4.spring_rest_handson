/**
 * Employee DAO - Data Access Layer
 * @Repository - Marks as DAO component
 * Manages in-memory employee data with CRUD operations
 */
@Repository
class EmployeeDao {
    
    private static final Logger LOGGER = LoggerFactory.getLogger(EmployeeDao.class);
    
    // In-memory employee list
    private static ArrayList<Employee> EMPLOYEE_LIST = new ArrayList<>();
    
    /**
     * Constructor - Loads employee data from XML
     */
    public EmployeeDao() {
        LOGGER.info("START - EmployeeDao Constructor");
        
        ApplicationContext context = new ClassPathXmlApplicationContext("employee.xml");
        @SuppressWarnings("unchecked")
        ArrayList<Employee> employees = context.getBean("employeeList", ArrayList.class);
        EMPLOYEE_LIST = employees;
        
        LOGGER.debug("Employee list loaded. Total employees: {}", EMPLOYEE_LIST.size());
        LOGGER.info("END - EmployeeDao Constructor");
    }
    
    /**
     * GET - Get all employees
     */
    public List<Employee> getAllEmployees() {
        LOGGER.debug("getAllEmployees() - Returning {} employees", EMPLOYEE_LIST.size());
        return new ArrayList<>(EMPLOYEE_LIST);
    }
    
    /**
     * GET - Get employee by ID
     */
    public Employee getEmployeeById(int id) throws EmployeeNotFoundException {
        LOGGER.debug("getEmployeeById() - Searching for employee: {}", id);
        
        return EMPLOYEE_LIST.stream()
                .filter(e -> e.getId() == id)
                .findFirst()
                .orElseThrow(() -> new EmployeeNotFoundException("Employee not found with id: " + id));
    }
    
    /**
     * POST - Add new employee
     */
    public void addEmployee(Employee employee) {
        LOGGER.debug("addEmployee() - Adding employee: {}", employee.getName());
        EMPLOYEE_LIST.add(employee);
        LOGGER.debug("Employee added. Total employees: {}", EMPLOYEE_LIST.size());
    }
    
    /**
     * PUT - Update existing employee
     */
    public void updateEmployee(Employee updatedEmployee) throws EmployeeNotFoundException {
        LOGGER.debug("updateEmployee() - Updating employee: {}", updatedEmployee.getId());
        
        // Find the existing employee
        Employee existingEmployee = getEmployeeById(updatedEmployee.getId());
        
        // Update all fields
        existingEmployee.setName(updatedEmployee.getName());
        existingEmployee.setGender(updatedEmployee.getGender());
        existingEmployee.setDateOfBirth(updatedEmployee.getDateOfBirth());
        existingEmployee.setDepartment(updatedEmployee.getDepartment());
        existingEmployee.setSkills(updatedEmployee.getSkills());
        existingEmployee.setSalary(updatedEmployee.getSalary());
        existingEmployee.setPermanent(updatedEmployee.getPermanent());
        
        LOGGER.debug("Employee updated successfully: {}", existingEmployee.getName());
    }
    
    /**
     * DELETE - Delete employee by ID
     */
    public void deleteEmployee(int id) throws EmployeeNotFoundException {
        LOGGER.debug("deleteEmployee() - Deleting employee: {}", id);
        
        Employee employee = getEmployeeById(id);
        EMPLOYEE_LIST.remove(employee);
        
        LOGGER.debug("Employee deleted. Remaining employees: {}", EMPLOYEE_LIST.size());
    }
}

