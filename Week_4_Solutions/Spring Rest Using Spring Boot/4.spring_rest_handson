/**
 * Employee Controller - REST API with Full CRUD Operations
 * 
 * REST URL Naming Guidelines:
 * - GET    /employees        - Get all employees
 * - GET    /employees/{id}   - Get employee by ID
 * - POST   /employees        - Create new employee (data in body)
 * - PUT    /employees        - Update employee (data in body)
 * - DELETE /employees/{id}   - Delete employee by ID
 */
@RestController
@RequestMapping("/employees")
class EmployeeController {
    
    private static final Logger LOGGER = LoggerFactory.getLogger(EmployeeController.class);
    
    @Autowired
    private EmployeeService employeeService;
    
    /**
     * GET /employees - Get all employees
     */
    @GetMapping
    public List<Employee> getAllEmployees() {
        LOGGER.info("START - EmployeeController.getAllEmployees()");
        List<Employee> employees = employeeService.getAllEmployees();
        LOGGER.info("END - EmployeeController.getAllEmployees() - Returned {} employees", employees.size());
        return employees;
    }
    
    /**
     * GET /employees/{id} - Get employee by ID
     */
    @GetMapping("/{id}")
    public Employee getEmployeeById(@PathVariable int id) throws EmployeeNotFoundException {
        LOGGER.info("START - EmployeeController.getEmployeeById() - ID: {}", id);
        Employee employee = employeeService.getEmployeeById(id);
        LOGGER.info("END - EmployeeController.getEmployeeById()");
        return employee;
    }
    
    /**
     * POST /employees - Create new employee
     * @Valid - Triggers validation
     * @RequestBody - Maps JSON to Java object
     */
    @PostMapping
    @ResponseStatus(HttpStatus.CREATED)
    public Employee addEmployee(@Valid @RequestBody Employee employee) {
        LOGGER.info("START - EmployeeController.addEmployee()");
        LOGGER.debug("Adding employee: {}", employee.getName());
        
        employeeService.addEmployee(employee);
        
        LOGGER.debug("Employee added with ID: {}", employee.getId());
        LOGGER.info("END - EmployeeController.addEmployee()");
        return employee;
    }
    
    /**
     * PUT /employees - Update existing employee
     * @Valid - Triggers validation
     * @RequestBody - Maps JSON to Java object
     */
    @PutMapping
    public Employee updateEmployee(@Valid @RequestBody Employee employee) throws EmployeeNotFoundException {
        LOGGER.info("START - EmployeeController.updateEmployee() - ID: {}", employee.getId());
        LOGGER.debug("Updating employee: {}", employee.getName());
        
        employeeService.updateEmployee(employee);
        
        LOGGER.debug("Employee updated: {}", employee.getName());
        LOGGER.info("END - EmployeeController.updateEmployee()");
        return employee;
    }
    
    /**
     * DELETE /employees/{id} - Delete employee by ID
     */
    @DeleteMapping("/{id}")
    public void deleteEmployee(@PathVariable int id) throws EmployeeNotFoundException {
        LOGGER.info("START - EmployeeController.deleteEmployee() - ID: {}", id);
        
        employeeService.deleteEmployee(id);
        
        LOGGER.debug("Employee deleted: {}", id);
        LOGGER.info("END - EmployeeController.deleteEmployee()");
    }
}

